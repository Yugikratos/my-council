node_modules/
npm-debug.log*

# Secrets — never commit. .env holds GEMINI_API_KEY etc.; .env.example is the
# tracked placeholder template (no real secrets) and is explicitly kept.
.env
.env.*
!.env.example

.DS_Store

# Python service venvs (memory service uses .venv; STT service uses .venv-stt)
.venv/
.venv-stt/
__pycache__/
*.pyc

# Local memory data (ChromaDB) — never commit conversation memory
memory-service/chroma-data/

# Vendored Piper TTS — binary + voice models are large and machine-specific, so
# each clone vendors its own (public repo). The folder structure stays tracked
# via tools/piper/voices/.gitkeep.
tools/piper/piper.exe
tools/piper/*.dll
tools/piper/*.ort
tools/piper/espeak-ng-data/
tools/piper/pkgconfig/
tools/piper/voices/*.onnx
tools/piper/voices/*.onnx.json

# Throwaway local TTS audition/diagnostic script (not part of the app).
/verify-tts.mjs
