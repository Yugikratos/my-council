# My Council — local secrets template.
#
# Copy this file to ".env" (which is gitignored) and fill in your real key:
#     cp .env.example .env      # or copy it in your editor
# Never commit .env. Never put a real key in THIS file.
#
# Optional hybrid cloud tier (used only for "/deep" messages). Get a free
# Google Gemini API key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-key-here

# --- Optional overrides (defaults are fine for most setups) ---
# Which Gemini model to use for /deep turns:
# GEMINI_MODEL=gemini-1.5-flash
# Set to false to disable the cloud tier entirely (/deep then stays local):
# CLOUD_ENABLED=true
